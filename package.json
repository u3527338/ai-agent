{
    "name": "lumos-agent",
    "version": "0.1.0",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "ollama": "ollama serve",
        "memory": "./venv_memory/bin/chroma run --path ./lumos_db",
        "python:listen": "python3 scripts/listener.py",
        "electron:start": "electron .",
        "lumos:core": "concurrently -n \"BRAIN,MEM,UI,EAR\" -c \"magenta.bold,cyan.bold,blue.bold,green.bold\" \"npm run ollama\" \"npm run memory\" \"npm run dev\" \"npm run python:listen\"",
        "dev:web": "npm run lumos:core",
        "dev:electron": "concurrently -n \"CORE,SHELL\" -c \"white.bold,yellow.bold\" \"npm run lumos:core\" \"wait-on http://localhost:3000 && npm run electron:start\"",
        "system-launch": "docker-compose up --build",
        "memory:check": "./venv_memory/bin/pip show chromadb"
    },
    "dependencies": {
        "axios": "^1.15.2",
        "chromadb": "^3.4.3",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.9.0",
        "next": "16.2.4",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "recharts": "^3.8.1",
        "server-only": "^0.0.1",
        "systeminformation": "^5.31.5"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "concurrently": "^9.2.1",
        "electron": "^41.3.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.4",
        "tailwindcss": "^4",
        "typescript": "^5",
        "wait-on": "^9.0.5"
    }
}
